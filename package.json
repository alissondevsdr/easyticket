{
  "name": "easyticket",
  "version": "1.0.0",
  "description": "Painel de controle para gestão de eventos - EasyTicket",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "cd backend && npm run build",
    "build": "electron-builder --win",
    "build:all": "electron-builder --win --mac --linux"
  },
  "keywords": [],
  "author": "EasyTicket",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.easyticket.app",
    "productName": "EasyTicket",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*",
      "index.html"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "backend/node_modules/@prisma",
        "to": "backend/node_modules/@prisma",
        "filter": ["**/*", "!**/*.md"]
      },
      {
        "from": "backend/node_modules/prisma",
        "to": "backend/node_modules/prisma",
        "filter": ["**/*", "!**/*.md"]
      },
      {
        "from": "backend/node_modules/bcryptjs",
        "to": "backend/node_modules/bcryptjs",
        "filter": ["**/*"]
      },
      {
        "from": "backend/node_modules/whatsapp-web.js",
        "to": "backend/node_modules/whatsapp-web.js",
        "filter": ["**/*", "!**/*.md"]
      },
      {
        "from": "backend/node_modules/puppeteer-core",
        "to": "backend/node_modules/puppeteer-core",
        "filter": ["**/*", "!**/*.md"]
      },
      {
        "from": "backend/node_modules/qrcode",
        "to": "backend/node_modules/qrcode",
        "filter": ["**/*"]
      },
      {
        "from": "backend/prisma",
        "to": "backend/prisma",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/ico.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EasyTicket",
      "installerIcon": "assets/ico.ico",
      "uninstallerIcon": "assets/ico.ico",
      "installerHeaderIcon": "assets/ico.ico",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "EasyTicket-Portable-${version}.exe"
    }
  }
}